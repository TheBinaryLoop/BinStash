{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BinStashDb": "<from-keyvault>"
  },
  "Storage": {
    "AllowedRootPath": ""
  },
  "VersionGate": {
    "MinimumCliVersion": "1.0.0"
  },
  "RequestMetrics": {
    "Enabled": true,
    "SlowRequestThreshold": "00:00:05",
    "LogAllRequests": false,
    "ExpectedNonSuccessStatusCodes": [ 401, 403 ]
  }
}
